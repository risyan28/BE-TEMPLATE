{
  "name": "qc-amti-backend",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "pnpm run generate",
    "dev": "scripts\\server\\dev-server.cmd",
    "dev:direct": "concurrently \"tsc --watch\" \"nodemon\"",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "start": "scripts\\server\\start-server.cmd",
    "start:direct": "node dist/index.js",
    "stop": "scripts\\server\\stop-server.cmd",
    "restart": "scripts\\server\\restart-server.cmd",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "generate": "prisma generate",
    "seed": "tsx prisma/seed.ts",
    "db:pull": "prisma db pull",
    "db:push": "prisma db push",
    "studio": "prisma studio",
    "bundle:be": "node build-backend-bundle.js",
    "docs:generate": "node scripts\\docs\\generate-docs.js",
    "docs:pdf": "powershell -ExecutionPolicy Bypass -File scripts\\docs\\generate-pdf.ps1",
    "docs:docx": "powershell -ExecutionPolicy Bypass -File scripts\\docs\\generate-docx.ps1",
    "docs:all": "pnpm run docs:generate && pnpm run docs:pdf",
    "check:conflicts": "node .\\scripts\\check-conflict-markers.mjs",
    "check:conflicts:all": "node .\\scripts\\check-conflict-markers.mjs --all",
    "hooks:install": "git config core.hooksPath .githooks",
    "git:solo": "node scripts/git-solo.mjs",
    "git:team": "node scripts/git-team.mjs",
    "git:new": "git checkout -b"
  },
  "_moduleAliases": {
    "@": "dist"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@opentelemetry/auto-instrumentations-node": "^0.69.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.211.0",
    "@opentelemetry/resources": "^2.5.0",
    "@opentelemetry/sdk-node": "^0.211.0",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "@prisma/client": "^6.19.2",
    "@sentry/node": "^10.38.0",
    "@sentry/profiling-node": "^10.38.0",
    "@types/mssql": "^9.1.8",
    "@types/multer": "^2.1.0",
    "@types/uuid": "^11.0.0",
    "bcryptjs": "^3.0.3",
    "cfb": "^1.2.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.2",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "hyperformula": "^3.2.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "module-alias": "^2.2.3",
    "mssql": "^11.0.1",
    "multer": "^2.1.1",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "puppeteer": "^24.40.0",
    "socket.io": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5",
    "xlsx-populate": "^1.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/exceljs": "^1.3.2",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.3.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/web-push": "^3.6.4",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.11",
    "prisma": "^6.19.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
